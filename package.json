{
  "name": "moonchat",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first chat aggregation desktop app with Telegram bot and AI memory system.",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:main": "tsc -w -p tsconfig.node.json --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/dev-electron.mjs",
    "build": "npm run build:web && npm run build:main",
    "build:web": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "start": "electron dist-electron/electron/main.js",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@langchain/core": "^1.1.40",
    "@langchain/openai": "^1.4.4",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "langchain": "^1.3.3",
    "node-telegram-bot-api": "^0.67.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  }
}
